# Base de données (SQLite)
DATABASE_URL="file:./dev.db"

# URL de l'application (pour les liens dans les emails)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="votre@email.com"
SMTP_PASS="votre_mot_de_passe_app"
SMTP_FROM="Mon Entreprise <votre@email.com>"

# Informations de votre entreprise (pour les documents)
COMPANY_NAME="Mon Entreprise"
COMPANY_ADDRESS="1 rue de la Paix, 75001 Paris"
COMPANY_PHONE="01 23 45 67 89"
COMPANY_EMAIL="contact@monentreprise.com"
COMPANY_SIRET="123 456 789 00010"
COMPANY_TVA="FR 12 123456789"

# Google OAuth2 (Calendar + Gmail)
GOOGLE_CLIENT_ID="votre_google_client_id"
GOOGLE_CLIENT_SECRET="votre_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/google/callback"

# Google Gemini AI (analyse de pipeline + suggestions)
GEMINI_API_KEY="votre_gemini_api_key"

# Clay (webhook enrichissement prospects)
CLAY_WEBHOOK_SECRET="votre_clay_webhook_secret"
